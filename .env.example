# ForgePilot Environment Configuration
# Kopiere diese Datei zu .env und fülle die Werte aus

# ============== ERFORDERLICH ==============

# OpenAI API Key (für GPT-4o)
# Erstelle unter: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ============== OPTIONAL ==============

# GitHub Personal Access Token (für Import/Push)
# Erstelle unter: https://github.com/settings/tokens
# Benötigte Scopes: repo (Full control of private repositories)
GITHUB_TOKEN=github_pat_...

# ============== OLLAMA (OPTIONAL) ==============

# Ollama URL - Standard ist localhost
# Auf Unraid: http://192.168.x.x:11434 (IP deines Ollama-Containers)
OLLAMA_URL=http://localhost:11434

# Ollama Modell - Standard ist llama3
OLLAMA_MODEL=llama3

# LLM Provider Auswahl
# - auto: Nutzt Ollama wenn verfügbar, sonst OpenAI (empfohlen)
# - openai: Nur OpenAI verwenden
# - ollama: Nur Ollama verwenden
LLM_PROVIDER=auto

# ============== NICHT ÄNDERN ==============
# Diese Werte werden automatisch gesetzt

# MongoDB (Docker-intern)
# MONGO_URL=mongodb://mongodb:27017
# DB_NAME=forgepilot
