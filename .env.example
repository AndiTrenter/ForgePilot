# ForgePilot Environment Variables für Docker Compose
# Kopiere diese Datei zu .env und fülle die Werte aus

# OpenAI API Key (erforderlich)
# Erstelle deinen Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# GitHub Personal Access Token (optional, für GitHub Integration)
# Erstelle Token: https://github.com/settings/tokens
GITHUB_TOKEN=

# Ollama URL (optional, für lokale LLMs)
# Standard: http://host.docker.internal:11434 (Ollama auf Host-System)
OLLAMA_URL=http://host.docker.internal:11434
